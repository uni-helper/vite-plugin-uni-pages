{
  "name": "@vite-plugin-uni-pages/monorepo",
  "type": "module",
  "version": "0.4.1",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "description": "Use TypeScript to write pages.json of uni-app",
  "author": "KeJun",
  "license": "MIT",
  "homepage": "https://github.com/uni-helper/vite-plugin-uni-pages#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uni-helper/vite-plugin-uni-pages.git"
  },
  "bugs": "https://github.com/uni-helper/vite-plugin-uni-pages/issues",
  "keywords": [],
  "sideEffects": false,
  "scripts": {
    "dev": "pnpm -r --filter='./packages/*' --parallel run dev",
    "build": "rimraf --glob 'packages/*/dist' && pnpm -r --filter='./packages/*' run build && pnpm -r run build-post",
    "play:mp-weixin": "pnpm -C playground run dev:mp-weixin",
    "build:mp-weixin": "pnpm -C playground run build:mp-weixin",
    "play:web": "pnpm -C playground run dev:web",
    "build:web": "pnpm -C playground run build:web",
    "prepublishOnly": "pnpm build",
    "release": "bumpp",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "bumpp": "catalog:",
    "comment-json": "catalog:",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
