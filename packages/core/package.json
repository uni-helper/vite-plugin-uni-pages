{
  "name": "@uni-helper/vite-plugin-uni-pages",
  "type": "module",
  "version": "0.3.24",
  "description": "File system based routing for uni-app applications using Vite",
  "author": "KeJun",
  "maintainers": [
    {
      "email": "wurui.dev@gmail.com",
      "name": "ModyQyW",
      "url": "https://modyyw.top"
    }
  ],
  "license": "MIT",
  "funding": [
    "https://afdian.com/a/kejun",
    "https://github.com/ModyQyW/sponsors"
  ],
  "homepage": "https://github.com/uni-helper/vite-plugin-uni-pages#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uni-helper/vite-plugin-uni-pages.git"
  },
  "bugs": "https://github.com/uni-helper/vite-plugin-uni-pages/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./index.d.ts",
  "files": [
    "client.d.ts",
    "dist",
    "global.d.ts",
    "index.d.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "build-post": "exit 0",
    "dev": "tsdown --watch",
    "debug": "tsdown --sourcemap",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@babel/generator": "catalog:",
    "@babel/types": "catalog:",
    "@types/proper-lockfile": "catalog:",
    "@uni-helper/uni-env": "catalog:",
    "@vue/compiler-sfc": "catalog:",
    "ast-kit": "catalog:",
    "chokidar": "catalog:",
    "comment-json": "catalog:",
    "debug": "catalog:",
    "detect-indent": "catalog:",
    "detect-newline": "catalog:",
    "fast-glob": "catalog:",
    "json5": "catalog:",
    "kolorist": "catalog:",
    "lodash.groupby": "catalog:",
    "magic-string": "catalog:",
    "proper-lockfile": "catalog:",
    "typescript": "catalog:",
    "unconfig": "catalog:",
    "write-file-atomic": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@antfu/utils": "catalog:",
    "@types/babel__generator": "catalog:",
    "@types/debug": "catalog:",
    "@types/lodash.groupby": "catalog:",
    "@types/node": "catalog:",
    "@types/write-file-atomic": "catalog:",
    "vite": "catalog:"
  }
}
